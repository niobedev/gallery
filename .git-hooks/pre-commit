#!/bin/bash

# Pre-commit hook to regenerate manifest if .enc files are staged
# This hook runs generate-manifest.js if any .enc files are being committed

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.enc$')

if [ -n "$STAGED_FILES" ]; then
    echo "Encoded files detected, regenerating manifest.json..."
    
    if ! node scripts/generate-manifest.js; then
        echo "Error: Failed to generate manifest"
        exit 1
    fi
    
    git add manifest.json
    echo "manifest.json updated and added to commit"
fi

exit 0